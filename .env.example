STOCK_VIDEO_SOURCE=pexels
PEXELS_API_KEYS=replace-with-pexels-key
PIXABAY_API_KEYS=
NEWSROOM_LIVE_SIGNALS=false
NEWSROOM_RESEARCH_CHANNELS=gdelt,exa,rss,x,xiaohongshu
NEWSROOM_RESEARCH_MAX_RESULTS=12
NEWSROOM_SOCIAL_MAX_RESULTS=6
NEWSROOM_COMMAND_TIMEOUT_SECONDS=15
# Comma-separated trusted RSS/Atom feeds, optional.
NEWSROOM_RSS_FEEDS=

# Optional GCP/Vertex settings for Gemini/Veo experiments.
GCP_PROJECT_ID=mp-ai-video
GCP_REGION=asia-southeast1
VEO_MODEL_NAME=veo-3.1-generate-001
VEO_FAST_MODEL_NAME=veo-3.1-fast-generate-001

# Optional dubbing uses Google Cloud Text-to-Speech through ADC / Workload Identity.
